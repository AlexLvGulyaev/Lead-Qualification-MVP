# n8n Lead Qualification Assistant
# Environment Configuration Template
# Copy this file to .env and fill in your values
# Version: 1.1
# Architecture: Separate databases for n8n internal and business data

# ============================================================================
# PostgreSQL Configuration
# ============================================================================

# PostgreSQL user (default: n8n)
# This user owns both databases: n8n and lead_qualification
POSTGRES_USER=n8n

# PostgreSQL password (REQUIRED - must be set)
POSTGRES_PASSWORD=your_secure_password_here

# PostgreSQL external port (default: 15432)
# Only change if you have a port conflict
POSTGRES_PORT=15432

# NOTE: Databases are created automatically by init scripts:
#   - n8n: for n8n internal tables (workflows, executions, credentials)
#   - lead_qualification: for business tables (leads, messages, etc.)
# Do NOT set POSTGRES_DB - it's intentionally left unset to allow
# init scripts to create both databases separately.

# ============================================================================
# n8n Configuration
# ============================================================================

# n8n host (default: 0.0.0.0 for all interfaces)
N8N_HOST=0.0.0.0

# n8n port (default: 5678)
N8N_PORT=5678

# n8n protocol (http or https)
N8N_PROTOCOL=http

# Node environment (production or development)
NODE_ENV=production

# Basic auth username (default: admin)
N8N_BASIC_AUTH_USER=admin

# Basic auth password (REQUIRED - must be set)
N8N_BASIC_AUTH_PASSWORD=your_admin_password_here

# Log level (info, warn, error, debug)
N8N_LOG_LEVEL=info

# ============================================================================
# OpenAI API Configuration
# ============================================================================

# OpenAI API key (REQUIRED for AI classification)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# Telegram Bot Configuration
# ============================================================================

# Telegram Bot Token (REQUIRED for Telegram channel)
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================================
# CRM Configuration - Kommo (choose one: Kommo OR Bitrix24)
# ============================================================================

# Kommo access token (long-lived token)
# Get from: Kommo Settings -> API
KOMMO_ACCESS_TOKEN=your_kommo_access_token_here

# Kommo subdomain (your account subdomain)
KOMMO_SUBDOMAIN=yourcompany

# Kommo base URL (constructed from subdomain)
KOMMO_BASE_URL=https://yourcompany.kommo.com

# Kommo pipeline and status IDs
# Get from: Kommo Settings -> Pipelines -> click on pipeline
KOMMO_PIPELINE_ID=your_pipeline_id_here
KOMMO_STATUS_INCOMING=your_status_id_here
KOMMO_STATUS_INITIAL_CONTACT=your_status_id_here
KOMMO_STATUS_DISCUSSIONS=your_status_id_here
KOMMO_STATUS_DECISION_MAKING=your_status_id_here
KOMMO_STATUS_CONTRACT_DISCUSSION=your_status_id_here
KOMMO_STATUS_WON=142
KOMMO_STATUS_LOST=143

# Kommo status names (for display in Admin UI)
# These are the human-readable names of pipeline statuses
KOMMO_STATUS_NAME_INCOMING=Входящая заявка
KOMMO_STATUS_NAME_INITIAL_CONTACT=Первичный контакт
KOMMO_STATUS_NAME_DISCUSSIONS=Переговоры
KOMMO_STATUS_NAME_DECISION_MAKING=Принимается решение
KOMMO_STATUS_NAME_CONTRACT_DISCUSSION=Обсуждение контракта
KOMMO_STATUS_NAME_WON=Успешно реализовано
KOMMO_STATUS_NAME_LOST=Закрыто и не реализовано

# Kommo custom field IDs
# Get from: Kommo Settings -> Custom Fields
KOMMO_LEAD_TYPE_FIELD_ID=your_field_id_here
KOMMO_PRIORITY_FIELD_ID=your_field_id_here
KOMMO_CONFIDENCE_FIELD_ID=your_field_id_here
KOMMO_PUBLIC_NUMBER_FIELD_ID=your_field_id_here
KOMMO_CATEGORY_FIELD_ID=your_field_id_here
KOMMO_ACTION_FIELD_ID=your_field_id_here

# Kommo responsible user ID (for task assignment)
# Get from: Kommo Settings -> Users -> click on user -> see ID in URL
# Or extract from JWT token "sub" field
KOMMO_RESPONSIBLE_USER_ID=your_responsible_user_id_here

# ============================================================================
# CRM Configuration - Bitrix24 (alternative to Kommo)
# ============================================================================

# Bitrix24 webhook URL
# Format: https://yourcompany.bitrix24.ru/rest/1/your_webhook_code/
BITRIX24_WEBHOOK_URL=https://yourcompany.bitrix24.ru/rest/1/webhook_code_here/

# ============================================================================
# Timezone
# ============================================================================

# Application timezone (default: Europe/Moscow)
TIMEZONE=Europe/Moscow

# ============================================================================
# Optional: Alternative AI Providers
# ============================================================================

# Anthropic Claude API key (alternative to OpenAI)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GigaChat API key (alternative to OpenAI)
# GIGACHAT_API_KEY=your_gigachat_api_key_here

# ============================================================================
# Notes
# ============================================================================
#
# Required variables (must be set before starting):
#   - POSTGRES_PASSWORD
#   - N8N_BASIC_AUTH_PASSWORD
#   - OPENAI_API_KEY
#   - TELEGRAM_BOT_TOKEN
#   - KOMMO_ACCESS_TOKEN OR BITRIX24_WEBHOOK_URL (at least one)
#
# Database Architecture:
#   PostgreSQL server hosts two databases:
#   - 'n8n': n8n internal tables (workflows, executions, credentials)
#   - 'lead_qualification': business tables (leads, messages, etc.)
#
# Security recommendations:
#   - Use strong, unique passwords for POSTGRES_PASSWORD and N8N_BASIC_AUTH_PASSWORD
#   - Never commit .env file to version control
#   - Use different credentials for production and development