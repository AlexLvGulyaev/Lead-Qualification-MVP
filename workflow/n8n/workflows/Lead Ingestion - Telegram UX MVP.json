          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO leads (contact_id, source, status, public_number, created_at, updated_at)\nVALUES (\n  '{{ $json.contact_id }}',\n  'telegram',\n  'received',\n  generate_public_number(),\n  NOW(),\n  NOW()\n)\nRETURNING id AS lead_id, public_number, contact_id, source, status, created_at;",
        "options": {}
      },
      "id": "7222aa88-088a-4973-b5b8-a5faa1cc144a",
      "name": "Create Lead",
      "type": "n8n-nodes-base.postgres",
