    {
      "parameters": {
        "jsCode": "const routeData = $('Route Request').item.json;\nconst sessionData = $input.item.json;\nconst collected = sessionData.collected_data || {};\n\nreturn [{\n  json: {\n    telegram_id: routeData.telegram_id,\n    chat_id: routeData.chat_id,\n    full_name: collected.name || routeData.first_name || 'Неизвестный',\n    phone: collected.phone || '',\n    email: collected.email || '',\n    username: sessionData.username || '',\n    description: collected.description || ''\n  }\n}];"
      },
      "id": "b6a045c9-56dc-41c2-af17-76678e85623a",
      "name": "Prepare Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2320,
        4176
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH c AS (\n  SELECT find_or_create_contact_by_telegram(\n    '{{ $json.telegram_id }}',\n    {{ $json.full_name ? \"'\" + $json.full_name.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n    {{ $json.username ? \"'\" + $json.username.replace(/'/g, \"''\") + \"'\" : \"NULL\" }}\n  ) AS contact_id\n)\nUPDATE contacts\nSET\n  phone = {{ $json.phone ? \"'\" + $json.phone.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n  email = {{ $json.email ? \"'\" + $json.email.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n  updated_at = NOW()\nWHERE id = (SELECT contact_id FROM c)\nRETURNING id AS contact_id;",
        "options": {}
      },
      "id": "ca039b09-0fdd-4c4b-9285-7406d278cdd7",
      "name": "Find/Create Contact",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
