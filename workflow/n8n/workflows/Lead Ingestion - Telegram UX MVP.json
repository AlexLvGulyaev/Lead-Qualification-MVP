    {
      "parameters": {
        "jsCode": "const routeData = $('Route Request').item.json;\nconst sessionData = $input.item.json;\nconst collected = sessionData.collected_data || {};\n\nfunction safe(v, fallback = 'не указано') {\n  return String(v || fallback);\n}\n\nconst message = `📋 Проверьте данные заявки\n\n👤 Имя:\n${safe(collected.name)}\n\n📞 Телефон:\n${safe(collected.phone, 'не указан')}\n\n📧 E-mail:\n${safe(collected.email, 'не указан')}\n\n💬 Описание:\n${safe(collected.description)}\n\nПодтвердить отправку?`;\n\nreturn [{\n  json: {\n    chat_id: routeData.chat_id,\n    telegram_id: routeData.telegram_id,\n    message,\n    collected_data: collected\n  }\n}];"
      },
