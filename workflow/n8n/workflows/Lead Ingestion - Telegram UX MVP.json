    {
      "parameters": {
        "jsCode": "const update = $input.item.json;\n\nlet result = {\n  chat_id: null,\n  telegram_id: null,\n  username: null,\n  first_name: null,\n  last_name: null,\n  text: null,\n  is_callback: false,\n  callback_data: null,\n  message_id: null\n};\n\nif (update.callback_query) {\n  const cq = update.callback_query;\n  result.is_callback = true;\n  result.chat_id = cq.message.chat.id;\n  result.telegram_id = cq.from.id.toString();\n  result.username = cq.from.username || '';\n  result.first_name = cq.from.first_name || '';\n  result.last_name = cq.from.last_name || '';\n  result.callback_data = cq.data;\n  result.message_id = cq.message.message_id;\n} else if (update.message) {\n  const msg = update.message;\n  result.chat_id = msg.chat.id;\n  result.telegram_id = msg.from.id.toString();\n  result.username = msg.from.username || '';\n  result.first_name = msg.from.first_name || '';\n  result.last_name = msg.from.last_name || '';\n  result.text = msg.text || '';\n}\n\nreturn [{ json: result }];"
      },
      "id": "953a41cb-a359-4f46-95aa-3b3e9e747ce1",
      "name": "Parse Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1312,
        2576
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM get_or_create_telegram_session(\n  '{{ $json.telegram_id }}',\n  {{ $json.chat_id }},\n  {{ $json.username ? \"'\" + $json.username.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n  {{ $json.first_name ? \"'\" + $json.first_name.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n  {{ $json.last_name ? \"'\" + $json.last_name.replace(/'/g, \"''\") + \"'\" : \"NULL\" }}\n);",
        "options": {}
      },
      "id": "615f0e9b-98ac-4057-8b87-8560690830d2",
      "name": "Get Session",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1520,
        2576
