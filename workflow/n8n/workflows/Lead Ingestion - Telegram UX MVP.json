    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Update').item.json;\nconst session = $input.item.json;\n\nconst isCallback = parsed.is_callback;\nconst callbackData = parsed.callback_data || '';\nconst text = parsed.text || '';\nconst step = session.current_step || 'start';\n\nlet route = 'unknown';\n\nif (isCallback) {\n  if (callbackData === 'create_request') route = 'start_request';\n  else if (callbackData === 'help') route = 'help';\n  else if (callbackData === 'about') route = 'about';\n  else if (callbackData === 'confirm_yes') route = 'confirm_yes';\n  else if (callbackData === 'confirm_edit') route = 'confirm_edit';\n  else if (callbackData === 'confirm_cancel') route = 'confirm_cancel';\n  else if (callbackData === 'skip_email') route = 'skip_email';\n} else {\n  if (text.startsWith('/start')) route = 'main_menu';\n  else if (text.startsWith('/help')) route = 'help';\n  else if (text.startsWith('/about')) route = 'about';\n  else if (step === 'start') route = 'main_menu';\n  else if (step === 'name') route = 'collect_name';\n  else if (step === 'phone') route = 'collect_phone';\n  else if (step === 'email') route = 'collect_email';\n  else if (step === 'description') route = 'collect_description';\n  else if (step === 'confirm') route = 'waiting_confirm';\n}\n\nreturn [{\n  json: {\n    route, step,\n    session_id: session.id,\n    telegram_id: parsed.telegram_id,\n    chat_id: parsed.chat_id,\n    text, callback_data: callbackData,\n    is_callback: isCallback,\n    message_id: parsed.message_id,\n    collected_data: session.collected_data || {}\n  }\n}];"
      },
