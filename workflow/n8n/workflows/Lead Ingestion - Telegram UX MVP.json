    {
      "parameters": {
        "jsCode": "const leadData = $input.item.json;\nconst prepareData = $('Prepare Lead Data').item.json;\n\nreturn [{\n  json: {\n    lead_id: leadData.lead_id,\n    public_number: leadData.public_number,\n    contact_id: leadData.contact_id,\n    telegram_id: prepareData.telegram_id,\n    chat_id: prepareData.chat_id,\n    message_content: prepareData.description,\n    lead_created: leadData.created_at\n  }\n}];"
      },
