      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        1120,
        2576
      ],
      "webhookId": "470c12b0-5536-4eb3-b028-5dfac18a3384",
