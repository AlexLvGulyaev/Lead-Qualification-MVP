    {
      "parameters": {
        "operation": "executeQuery",
        "query": " INSERT INTO leads (contact_id, source, utm_source, utm_campaign, status, public_number, created_at, updated_at)\n  VALUES (\n    '{{ $json.contact_id }}',\n    '{{ $('Validate').item.json.lead.source }}',\n    {{ $('Validate').item.json.lead.utm_source ? \"'\" + $('Validate').item.json.lead.utm_source.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n    {{ $('Validate').item.json.lead.utm_campaign ? \"'\" + $('Validate').item.json.lead.utm_campaign.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n    'received',\n    generate_public_number(),\n    NOW(),\n    NOW()\n  )\n  RETURNING id AS lead_id, public_number, contact_id, source, status, created_at;",
        "options": {}
      },
