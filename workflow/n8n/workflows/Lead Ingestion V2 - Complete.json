        "operation": "executeQuery",
        "query": "SELECT find_or_create_contact_by_email_phone(\n  {{ $('Validate').item.json.lead.email ? \"'\" + $('Validate').item.json.lead.email.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n  {{ $('Validate').item.json.lead.phone ? \"'\" + $('Validate').item.json.lead.phone.replace(/'/g, \"''\") + \"'\" : \"NULL\" }},\n  {{ $('Validate').item.json.lead.name ? \"'\" + $('Validate').item.json.lead.name.replace(/'/g, \"''\") + \"'\" : \"NULL\" }}\n) AS contact_id;",
        "options": {}
